# ── claude-stats config ──────────────────────────────────────────────────────
# Copy this file to .env and edit it.

# Include the local machine (requires npx + ccusage)
LOCAL=true

# Remote machines via SSH — comma-separated, any number of hosts
# SSH_SOURCES=root@vps1.example.com
# SSH_SOURCES=root@vps1.example.com,user@vps2.example.com

# Command used on each SSH host to get ccusage JSON
# SSH_CCUSAGE=~/.bun/bin/bunx --bun ccusage --json 2>/dev/null

# Where Claude stores its project JSONL files (for local detail breakdown)
# CLAUDE_PROJECTS=~/.claude/projects

# SSH + subprocess timeout in seconds
# TIMEOUT=25
